# ProjectWorkbench Claude wrapper instance policy.
# Copy to /etc/project-workbench/claude-wrapper.env and adjust per deployment.

# Shared local memory directory exposed to every PW workspace with --add-dir.
PW_SHARED_MEMORY=/opt/project-workbench/memory

# MCP policy:
# - inherit: do not add --mcp-config/--strict-mcp-config; Claude may use account/project MCP normally.
# - isolated: force an empty strict MCP config; useful when account MCP servers are unreachable from this instance.
# - custom: force PW_MCP_CONFIG as strict MCP config; useful for a per-instance MCP server/config.
PW_MCP_MODE=inherit
PW_MCP_CONFIG=/etc/project-workbench/empty-mcp.json

# Permission policy:
# - prompt: Claude asks before each tool use (file edit, shell command, etc.).
#           Safe default. Use this unless everyone with dashboard access is fully trusted.
# - skip:   passes --dangerously-skip-permissions. Claude runs every tool unattended.
#           Anyone with basic-auth access effectively has shell on this box.
PW_PERMISSION_MODE=prompt

# Remote Control:
# - true:  appends --remote-control to interactive sessions so they can be
#          driven by tooling that speaks Claude Code's remote-control protocol.
#          Skipped automatically for --print / -p (non-interactive) invocations.
# - false: leave --remote-control off; user can still enable it ad-hoc per session.
PW_REMOTE_CONTROL=true
