#!/usr/bin/env bash
set -euo pipefail
LOG=/var/log/claude-code-update.log
WORKBENCH_JSON=/etc/project-workbench/workbench.json

cli_pkg() {
  case "$1" in
    claude)  echo "@anthropic-ai/claude-code" ;;
    codex)   echo "@openai/codex" ;;
    copilot) echo "@github/copilot" ;;
    *)       echo "" ;;
  esac
}

install_claude_wrapper() {
  # Keep npm-managed /bin/claude and /usr/bin/claude symlinks untouched.
  # Put a stable local wrapper earlier in PATH. Blanket permissions and shared memory are common
  # to PW instances; MCP behavior is instance-local via /etc/project-workbench/claude-wrapper.env.
  rm -f /usr/local/bin/claude
  cat > /usr/local/bin/claude <<'BASH'
#!/usr/bin/env bash
set -euo pipefail
REAL=/usr/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe
CONFIG=/etc/project-workbench/claude-wrapper.env

PW_SHARED_MEMORY=/opt/project-workbench/memory
PW_MCP_MODE=inherit
PW_MCP_CONFIG=/etc/project-workbench/empty-mcp.json
PW_PERMISSION_MODE=prompt
PW_REMOTE_CONTROL=true
if [[ -f "$CONFIG" ]]; then
  # shellcheck source=/etc/project-workbench/claude-wrapper.env
  source "$CONFIG"
fi

args=()
has_permission=0
has_add_dir=0
has_mcp_config=0
has_remote_control=0
has_print=0
for arg in "$@"; do
  case "$arg" in
    --permission-mode|--permission-mode=*|--dangerously-skip-permissions|--allow-dangerously-skip-permissions)
      has_permission=1
      ;;
    --add-dir|--add-dir=*)
      has_add_dir=1
      ;;
    --mcp-config|--mcp-config=*|--strict-mcp-config)
      has_mcp_config=1
      ;;
    --remote-control|--remote-control=*|--remote-control-session-name-prefix|--remote-control-session-name-prefix=*)
      has_remote_control=1
      ;;
    -p|--print)
      has_print=1
      ;;
  esac
done

if [[ "$has_permission" -eq 0 && "${PW_PERMISSION_MODE:-prompt}" == "skip" ]]; then
  args+=(--dangerously-skip-permissions)
fi
if [[ "$has_add_dir" -eq 0 && -n "${PW_SHARED_MEMORY:-}" && -d "$PW_SHARED_MEMORY" ]]; then
  args+=(--add-dir "$PW_SHARED_MEMORY")
fi
# Remote-control is an interactive-only feature; skip for --print runs so we
# don't break non-interactive pipes.
if [[ "$has_remote_control" -eq 0 && "$has_print" -eq 0 && "${PW_REMOTE_CONTROL:-true}" == "true" ]]; then
  args+=(--remote-control)
fi
if [[ "$has_mcp_config" -eq 0 ]]; then
  case "${PW_MCP_MODE:-inherit}" in
    inherit)
      ;;
    isolated)
      if [[ -f "$PW_MCP_CONFIG" ]]; then
        args+=(--mcp-config "$PW_MCP_CONFIG" --strict-mcp-config)
      fi
      ;;
    custom)
      if [[ -f "$PW_MCP_CONFIG" ]]; then
        args+=(--mcp-config "$PW_MCP_CONFIG" --strict-mcp-config)
      else
        echo "PW_MCP_MODE=custom but PW_MCP_CONFIG not found: $PW_MCP_CONFIG" >&2
        exit 1
      fi
      ;;
    *)
      echo "Invalid PW_MCP_MODE: $PW_MCP_MODE (expected inherit, isolated, or custom)" >&2
      exit 1
      ;;
  esac
fi

exec "$REAL" "${args[@]}" "$@"
BASH
  chmod +x /usr/local/bin/claude
}

update_one() {
  local cli="$1"
  local pkg
  pkg="$(cli_pkg "$cli")"
  if [[ -z "$pkg" ]]; then
    echo "Unknown CLI: $cli" >&2
    return 1
  fi
  echo "----- $(date -Is) updating $cli ($pkg) -----"
  if [[ "$cli" == "claude" ]]; then
    echo "Before: $(/usr/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe --version 2>/dev/null || echo missing)"
  else
    echo "Before: $(command -v "$cli" >/dev/null && "$cli" --version 2>/dev/null || echo missing)"
  fi
  npm install -g "$pkg@latest"
  if [[ "$cli" == "claude" ]]; then
    install_claude_wrapper
    echo "After:  $(/usr/local/bin/claude --version 2>/dev/null || echo missing)"
  else
    echo "After:  $(command -v "$cli" >/dev/null && "$cli" --version 2>/dev/null || echo missing)"
  fi
}

read_update_clis() {
  if [[ -f "$WORKBENCH_JSON" ]] && command -v jq >/dev/null; then
    jq -r '(.updateClis // ["claude"]) | .[]' "$WORKBENCH_JSON"
  else
    echo claude
  fi
}

{
  echo "===== $(date -Is) PW CLI update start ====="
  mapfile -t CLIS < <(read_update_clis)
  if [[ ${#CLIS[@]} -eq 0 ]]; then
    echo "No CLIs configured in $WORKBENCH_JSON; defaulting to claude"
    CLIS=(claude)
  fi
  for cli in "${CLIS[@]}"; do
    update_one "$cli" || echo "Failed to update $cli"
  done
  systemctl restart project-workbench.service || true
  echo "===== $(date -Is) PW CLI update complete ====="
} >> "$LOG" 2>&1
