#!/usr/bin/env bash
set -euo pipefail
name="$1"
json=/opt/project-workbench/projects.json
path=$(jq -r --arg n "$name" '.[] | select(.name==$n) | .path' "$json")
port=$(jq -r --arg n "$name" '.[] | select(.name==$n) | .port' "$json")
repo=$(jq -r --arg n "$name" '.[] | select(.name==$n) | .repo' "$json")
[[ -n "$path" && "$path" != null && -n "$port" && "$port" != null ]] || { echo "Unknown project: $name" >&2; exit 1; }
mkdir -p "$path"
real_path=$(readlink -f "$path")
chown -R admin:admin "$real_path" 2>/dev/null || true
cd "$real_path"
if [[ -d .git ]]; then
  git config --global --add safe.directory "$real_path" 2>/dev/null || true
elif [[ -n "$repo" && "$repo" != null ]]; then
  echo "Workspace not cloned yet. Run: git clone $repo ."
fi
claude_path=$(command -v claude || true)
[[ -n "$claude_path" ]] || claude_path="missing"
# ProjectWorkbench terminals are created only for managed local workspaces.
# Pre-mark them trusted so CRUD-created projects open Claude Code immediately.
python3 - "$real_path" <<'PY' 2>/dev/null || true
import json, os, sys, time
path=sys.argv[1]
conf=os.path.expanduser('~/.claude.json')
try:
    with open(conf) as f: data=json.load(f)
except Exception:
    data={}
projects=data.setdefault('projects', {})
entry=projects.setdefault(path, {})
entry.setdefault('allowedTools', [])
entry.setdefault('mcpContextUris', [])
entry.setdefault('mcpServers', {})
entry.setdefault('enabledMcpjsonServers', [])
entry.setdefault('disabledMcpjsonServers', [])
entry['hasTrustDialogAccepted']=True
entry.setdefault('projectOnboardingSeenCount', 0)
entry.setdefault('hasClaudeMdExternalIncludesApproved', False)
entry.setdefault('hasClaudeMdExternalIncludesWarningShown', False)
entry.setdefault('hasCompletedProjectOnboarding', True)
entry.setdefault('lastGracefulShutdown', True)
tmp=conf+'.tmp'
with open(tmp,'w') as f: json.dump(data,f,indent=2)
os.replace(tmp, conf)
PY
session="pw_${name//[^A-Za-z0-9_]/_}"
tab_env='env HOME=/home/admin LANG=C.UTF-8 LC_ALL=C.UTF-8 TERM=screen-256color COLORTERM=truecolor PATH=/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin bash --noprofile --norc'
# Create the project tmux session once. Future browser sessions reattach to the same shell/process state.
if ! tmux has-session -t "$session" 2>/dev/null; then
  tmux -u new-session -d -s "$session" -c "$real_path" "$tab_env"
  tmux send-keys -t "$session" "printf 'Project workspace: %s\nClaude: %s\nPersistent console: tmux session %s\nTip: run claude from here after auth is completed.\n\n' '$real_path' '$claude_path' '$session'" C-m
  # Auto-spawn tab templates flagged autoStart. The cmd is typed into the
  # new window via send-keys so the shell stays alive after it exits.
  while IFS=$'\t' read -r tab_name tab_cmd; do
    [[ -z "$tab_name" ]] && continue
    tmux new-window -t "$session" -c "$real_path" -n "$tab_name" "$tab_env" || continue
    if [[ -n "$tab_cmd" ]]; then
      tmux send-keys -t "$session:$tab_name" "$tab_cmd" C-m
    fi
  done < <(jq -r --arg n "$name" '.[] | select(.name==$n) | .tabs // [] | .[] | select(.autoStart==true) | "\(.name)\t\(.cmd // "")"' "$json")
  tmux select-window -t "$session:0" 2>/dev/null || true
fi
exec /usr/bin/ttyd \
  --interface 127.0.0.1 \
  --port "$port" \
  --base-path "/pty/$name" \
  --writable \
  --terminal-type xterm-256color \
  --client-option fontFamily=monospace \
  --client-option fontSize=14 \
  --client-option lineHeight=1 \
  --client-option letterSpacing=0 \
  --check-origin \
  tmux -u attach-session -t "$session"
